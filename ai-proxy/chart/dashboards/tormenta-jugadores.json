   "gridPos": {
    "h": 8,
    "w": 8,
    "x": 0,
    "y": 19
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "options": {
    "legend": {
     "displayMode": "table",
     "placement": "right",
     "values": [
      "value"
     ]
    },
    "pieType": "donut"
   },
   "targets": [
    {
     "expr": "sum by (result) (increase(tormenta_game_events_total{event=\"minigame\"}[24h]))",
     "legendFormat": "{{result}}",
     "refId": "A"
    }
   ]
  },
  {
   "type": "piechart",
   "title": "Arcade: a qué juegan (24h)",
   "gridPos": {
