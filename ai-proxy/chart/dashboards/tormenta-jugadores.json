{
 "title": "Tormenta Solar — Jugadores (cómo juega la gente)",
 "uid": "tormenta-jugadores",
 "tags": [
  "tormenta-solar",
  "jugadores"
 ],
 "timezone": "",
 "schemaVersion": 39,
 "refresh": "30s",
 "time": {
  "from": "now-24h",
  "to": "now"
 },
 "templating": {
  "list": [
   {
    "name": "datasource",
    "type": "datasource",
    "query": "prometheus",
    "current": {},
    "hide": 0,
    "label": "Datasource"
   }
  ]
 },
 "panels": [
  {
   "type": "stat",
   "title": "Jugando AHORA",
   "gridPos": {
    "h": 6,
    "w": 4,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value"
   },
   "targets": [
    {
     "expr": "sum(tormenta_players_online)",
     "legendFormat": "",
     "refId": "A"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "Online en el tiempo (cuándo juega la gente)",
   "gridPos": {
    "h": 6,
    "w": 10,
    "x": 4,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 20,
      "lineWidth": 2
     }
    }
   },
   "targets": [
    {
     "expr": "sum(tormenta_players_online)",
     "legendFormat": "online",
     "refId": "A"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "Sesiones/hora por idioma",
   "gridPos": {
    "h": 6,
    "w": 10,
    "x": 14,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "custom": {
      "drawStyle": "bars",
      "fillOpacity": 60,
      "lineWidth": 2,
      "stacking": {
       "mode": "normal"
      }
     }
    }
   },
   "targets": [
    {
     "expr": "sum by (lang) (increase(tormenta_game_events_total{event=\"session\"}[1h]))",
     "legendFormat": "{{lang}}",
     "refId": "A"
    }
   ]
  },
  {
   "type": "stat",
   "title": "% que dispara la TORMENTA (24h)",
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 0,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "steps": [
       {
        "color": "yellow",
        "value": null
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value"
   },
   "targets": [
    {
     "expr": "100 * sum(increase(tormenta_game_events_total{event=\"storm\"}[24h])) / clamp_min(sum(increase(tormenta_game_events_total{event=\"session\"}[24h])), 1)",
     "legendFormat": "",
     "refId": "A"
    }
   ]
  },
  {
   "type": "stat",
   "title": "% que TERMINA el nivel (24h)",
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 4,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value"
   },
   "targets": [
    {
     "expr": "100 * sum(increase(tormenta_game_events_total{event=\"win\"}[24h])) / clamp_min(sum(increase(tormenta_game_events_total{event=\"session\"}[24h])), 1)",
     "legendFormat": "",
     "refId": "A"
    }
   ]
  },
  {
   "type": "stat",
   "title": "Muertes (24h)",
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 8,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "steps": [
       {
        "color": "red",
        "value": null
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value"
   },
   "targets": [
    {
     "expr": "sum(increase(tormenta_game_events_total{event=\"death\"}[24h]))",
     "legendFormat": "",
     "refId": "A"
    }
   ]
  },
  {
   "type": "stat",
   "title": "Minutos JUGADOS (24h)",
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 12,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "m",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "steps": [
       {
        "color": "blue",
        "value": null
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value"
   },
   "targets": [
    {
     "expr": "5 * sum(increase(tormenta_game_events_total{event=\"playtime\"}[24h]))",
     "legendFormat": "",
     "refId": "A"
    }
   ]
  },
  {
   "type": "stat",
   "title": "Duración media de sesión (min)",
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 16,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "m",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "steps": [
       {
        "color": "blue",
        "value": null
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value"
   },
   "targets": [
    {
     "expr": "5 * sum(increase(tormenta_game_events_total{event=\"playtime\"}[24h])) / clamp_min(sum(increase(tormenta_game_events_total{event=\"session\"}[24h])), 1)",
     "legendFormat": "",
     "refId": "A"
    }
   ]
  },
  {
   "type": "stat",
   "title": "Truco: ganados (24h)",
   "gridPos": {
    "h": 5,
    "w": 4,
    "x": 20,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "color": {
      "mode": "thresholds"
     },
     "thresholds": {
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     }
    }
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "textMode": "value"
   },
   "targets": [
    {
     "expr": "sum(increase(tormenta_game_events_total{event=\"truco\", result=\"win\"}[24h]))",
     "legendFormat": "",
     "refId": "A"
    }
   ]
  },
  {
   "type": "timeseries",
   "title": "DÓNDE está la gente — en el tiempo (por lugar)",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 11
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 45,
      "lineWidth": 2,
      "stacking": {
       "mode": "normal"
      }
     }
    }
   },
   "targets": [
    {
     "expr": "sum by (sala) (tormenta_players_by_sala)",
     "legendFormat": "{{sala}}",
     "refId": "A"
    }
   ]
  },
  {
   "type": "barchart",
   "title": "Quests / hitos completados (24h) — el CAMINO que recorre la gente",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 11
   },
   "datasource": {
    "type": "prometheus",
    "uid": "${datasource}"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short",
     "color": {
      "mode": "palette-classic"
     }
    }
   },
   "options": {
    "orientation": "horizontal"
   },
   "targets": [
    {
     "expr": "sum by (result) (increase(tormenta_game_events_total{event=\"quest\"}[24h]))",
     "legendFormat": "{{result}}",
     "refId": "A"
    }
   ]
  },
  {
